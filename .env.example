# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.bdkhujnxzdougfvziaxw:7r7uzxakk360@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379

# ─── Google APIs ─────────────────────────────────────────
# Backend key: restrict to server IP in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_backend_key_here

# ─── AI Provider ─────────────────────────────────────────
AI_PROVIDER=openai                   # 'openai' | 'gemini'
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=                      # Leave blank if using OpenAI
GEMINI_MODEL=gemini-1.5-flash

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_64_char_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── App ─────────────────────────────────────────────────
ENVIRONMENT=local                    # 'local' | 'staging' | 'production'
ALLOWED_ORIGINS=http://localhost:3000
SENTRY_DSN=                          # Leave blank for local dev

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_AI=10/minute
RATE_LIMIT_PLACES=30/minute
RATE_LIMIT_AUTH=5/minute

# ─── Cache TTLs (seconds) ─────────────────────────────────
CACHE_TTL_PLACES=600
CACHE_TTL_FEES=86400
CACHE_TTL_GEOCODE=604800

# ─── Frontend (apps/web/.env.local) ──────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000/v1
# Frontend key: restrict to HTTP referrer localhost:3000 in Google Cloud Console
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_frontend_key_here
# NEXT_PUBLIC_ENVIRONMENT=local
